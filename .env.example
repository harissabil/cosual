# ── Cosual — Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Alibaba Cloud Model Studio API key (required)
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# Backend database URL (default: SQLite file inside the container)
# DATABASE_URL=sqlite+aiosqlite:///./cosual.db

# Domain or public IP of your server (used by frontend build)
# Set this to your Alibaba SAS public IP or domain name
DOMAIN=localhost

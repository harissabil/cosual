# ── Cosual — Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Alibaba Cloud Model Studio API key (required)
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# API key to protect backend endpoints (optional — if empty, auth is disabled)
COSUAL_API_KEY=your-secret-api-key-here
